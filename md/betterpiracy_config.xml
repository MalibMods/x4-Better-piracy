<?xml version="1.0" encoding="utf-8" ?>
<mdscript name="Betterpiracy_config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://x4libonline.ddns.net/libraries/md.xsd">
  <cues>
    <cue name="Config" version="1">
      <actions>
        <include_actions ref="Reset_Config"/>
      </actions>
    </cue>

    <library name="Reset_Config">
      <actions>
        <set_value
          name="Config.$Config"
          exact="table[
            $harass_shield_threshold = 20,
            $early_harass_hull_threshold = 75,
            $harass_bail_attemps_before_mid = 3,
            $mid_harass_hull_threshold = 50,
            $harass_bail_attemps_before_late = 6,
            $late_harass_hull_threshold = 25,
            $keep_pressure_timer = 10,
            $keep_pressure_max_distance_sm = 3,
            $keep_pressure_max_distance_lxl = 6,
            $pressure_buildup_rate = 1,
            $harass_lxl_min_crew_left_base = 25,
            $harass_lxl_min_crew_left_pilot = 25,
            $harass_base_bail_chance = 60,
            $harass_base_bail_number = 20,
            $harass_reputation_hit = 1,
            $harass_bailing_pilots_damage_hull = 0,
            $harass_bailing_pilots_destroy_components = 0,
            $harass_bailing_pilots_destroy_cargo = 0,
            $combat_base_bail_chance = 36,
            $combat_reputation_hit = 1,
            $combat_bailing_pilots_damage_hull = 0,
            $combat_bailing_pilots_destroy_components = 0,
            $combat_bailing_pilots_destroy_cargo = 0
          ]"
        />
      </actions>
    </library>

    <!-- Register the submenu entry in Extension Options. -->
    <cue name="Register_Menu" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Simple_Menu_Options.Reloaded"/>
      </conditions>
      <actions>
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Register_Options_Menu"
          param="table[
            $id      = 'betterpiracy_options_menu',
            $columns = 2,
            $title   = 'Better Piracy Reforged',
            $onOpen  = BuildOptionsMenu
          ]"
        />
        <cancel_cue cue="this"/>
      </actions>
    </cue>

    <!-- Build the options menu when opened. -->
    <cue name="BuildOptionsMenu" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <debug_to_file name="'BetterPiracy'" text="'%s --- Betterpiracy_config --- BuildOptionsMenu: current values: shield=%s, early_hull=%s, bail_mid=%s, mid_hull=%s, bail_late=%s, late_hull=%s, pressure_timer=%s, dist_sm=%s, dist_lxl=%s, buildup=%s, crew_base=%s, crew_pilot=%s, bail_chance=%s, bail_num=%s, rep_hit=%s, dmg_hull=%s, destroy_comp=%s, destroy_cargo=%s, combat_bail=%s, combat_rep=%s, combat_dmg=%s, combat_comp=%s, combat_cargo=%s'.[player.age, Config.$Config.$harass_shield_threshold, Config.$Config.$early_harass_hull_threshold, Config.$Config.$harass_bail_attemps_before_mid, Config.$Config.$mid_harass_hull_threshold, Config.$Config.$harass_bail_attemps_before_late, Config.$Config.$late_harass_hull_threshold, Config.$Config.$keep_pressure_timer, Config.$Config.$keep_pressure_max_distance_sm, Config.$Config.$keep_pressure_max_distance_lxl, Config.$Config.$pressure_buildup_rate, Config.$Config.$harass_lxl_min_crew_left_base, Config.$Config.$harass_lxl_min_crew_left_pilot, Config.$Config.$harass_base_bail_chance, Config.$Config.$harass_base_bail_number, Config.$Config.$harass_reputation_hit, Config.$Config.$harass_bailing_pilots_damage_hull, Config.$Config.$harass_bailing_pilots_destroy_components, Config.$Config.$harass_bailing_pilots_destroy_cargo, Config.$Config.$combat_base_bail_chance, Config.$Config.$combat_reputation_hit, Config.$Config.$combat_bailing_pilots_damage_hull, Config.$Config.$combat_bailing_pilots_destroy_components, Config.$Config.$combat_bailing_pilots_destroy_cargo]"/>

        <!-- ── Harass Settings ── -->
        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $colSpan=2, $text='Harass Settings']"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5151}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='harass_shield_threshold',
          $min=11, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$harass_shield_threshold,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5153}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='early_harass_hull_threshold',
          $min=1, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$early_harass_hull_threshold,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5155}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='harass_bail_attemps_before_mid',
          $min=1, $max=100, $step=1,
          $start=Config.$Config.$harass_bail_attemps_before_mid,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5157}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='mid_harass_hull_threshold',
          $min=1, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$mid_harass_hull_threshold,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5159}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='harass_bail_attemps_before_late',
          $min=1, $max=100, $step=1,
          $start=Config.$Config.$harass_bail_attemps_before_late,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5161}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='late_harass_hull_threshold',
          $min=1, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$late_harass_hull_threshold,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5163}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='keep_pressure_timer',
          $min=0, $max=30, $step=1, $suffix=' seconds',
          $start=Config.$Config.$keep_pressure_timer,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5165}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='keep_pressure_max_distance_sm',
          $min=0, $max=15, $step=1, $suffix=' km',
          $start=Config.$Config.$keep_pressure_max_distance_sm,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5167}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='keep_pressure_max_distance_lxl',
          $min=0, $max=30, $step=1, $suffix=' km',
          $start=Config.$Config.$keep_pressure_max_distance_lxl,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5169}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='pressure_buildup_rate',
          $min=0, $max=3, $step=0.25,
          $start=Config.$Config.$pressure_buildup_rate,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5171}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='harass_lxl_min_crew_left_base',
          $min=0, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$harass_lxl_min_crew_left_base,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5173}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='harass_lxl_min_crew_left_pilot',
          $min=0, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$harass_lxl_min_crew_left_pilot,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5175}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='harass_base_bail_chance',
          $min=0, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$harass_base_bail_chance,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5177}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='harass_base_bail_number',
          $min=0, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$harass_base_bail_number,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5179}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $col=2, $id='harass_reputation_hit',
          $checked=Config.$Config.$harass_reputation_hit == 1,
          $width='Helper.standardButtonHeight', $height='Helper.standardButtonHeight',
          $onClick=OnCheckboxChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5181}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $col=2, $id='harass_bailing_pilots_damage_hull',
          $checked=Config.$Config.$harass_bailing_pilots_damage_hull == 1,
          $width='Helper.standardButtonHeight', $height='Helper.standardButtonHeight',
          $onClick=OnCheckboxChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5183}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $col=2, $id='harass_bailing_pilots_destroy_components',
          $checked=Config.$Config.$harass_bailing_pilots_destroy_components == 1,
          $width='Helper.standardButtonHeight', $height='Helper.standardButtonHeight',
          $onClick=OnCheckboxChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text='Harass: destroy cargo']"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $col=2, $id='harass_bailing_pilots_destroy_cargo',
          $checked=Config.$Config.$harass_bailing_pilots_destroy_cargo == 1,
          $width='Helper.standardButtonHeight', $height='Helper.standardButtonHeight',
          $onClick=OnCheckboxChange
        ]"/>

        <!-- ── Combat Settings ── -->
        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $colSpan=2, $text='Combat Settings']"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5185}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Slider" param="table[
          $col=2, $id='combat_base_bail_chance',
          $min=0, $max=100, $step=1, $suffix='%',
          $start=Config.$Config.$combat_base_bail_chance,
          $onSliderCellConfirm=OnSliderChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5187}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $col=2, $id='combat_reputation_hit',
          $checked=Config.$Config.$combat_reputation_hit == 1,
          $width='Helper.standardButtonHeight', $height='Helper.standardButtonHeight',
          $onClick=OnCheckboxChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5189}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $col=2, $id='combat_bailing_pilots_damage_hull',
          $checked=Config.$Config.$combat_bailing_pilots_damage_hull == 1,
          $width='Helper.standardButtonHeight', $height='Helper.standardButtonHeight',
          $onClick=OnCheckboxChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={61537, 5191}]"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $col=2, $id='combat_bailing_pilots_destroy_components',
          $checked=Config.$Config.$combat_bailing_pilots_destroy_components == 1,
          $width='Helper.standardButtonHeight', $height='Helper.standardButtonHeight',
          $onClick=OnCheckboxChange
        ]"/>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text='Combat: destroy cargo']"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_CheckBox" param="table[
          $col=2, $id='combat_bailing_pilots_destroy_cargo',
          $checked=Config.$Config.$combat_bailing_pilots_destroy_cargo == 1,
          $width='Helper.standardButtonHeight', $height='Helper.standardButtonHeight',
          $onClick=OnCheckboxChange
        ]"/>

        <!-- ── Reset ── -->
        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Button" param="table[
          $col=1, $colSpan=2,
          $text=table[$text='Reset to Defaults'],
          $onClick=OnReset
        ]"/>

        <cancel_cue cue="this"/>
      </actions>
    </cue>

    <!-- Slider value changed. -->
    <cue name="OnSliderChange" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <debug_to_file name="'BetterPiracy'" text="'%s --- Betterpiracy_config --- Slider changed: %s = %s'.[player.age, event.param.$id, event.param.$value]"/>
        <set_value name="Config.$Config.{'$' + event.param.$id}" exact="event.param.$value"/>
        <cancel_cue cue="this"/>
      </actions>
    </cue>

    <!-- Checkbox toggled. -->
    <cue name="OnCheckboxChange" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <debug_to_file name="'BetterPiracy'" text="'%s --- Betterpiracy_config --- Checkbox changed: %s = %s'.[player.age, event.param.$id, event.param.$checked]"/>
        <set_value name="Config.$Config.{'$' + event.param.$id}" exact="if event.param.$checked then 1 else 0"/>
        <cancel_cue cue="this"/>
      </actions>
    </cue>

    <!-- Reset all values to defaults and refresh the menu. -->
    <cue name="OnReset" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <debug_to_file name="'BetterPiracy'" text="'%s --- Betterpiracy_config --- Reset to defaults.'.[player.age]"/>
        <include_actions ref="Reset_Config"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Refresh_Menu"/>
        <cancel_cue cue="this"/>
      </actions>
    </cue>

  </cues>
</mdscript>
